{
  "name": "typescript-to-vba",
  "version": "1.0.1",
  "description": "Professional TypeScript to VBA transpiler for Excel/Office automation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dEN5-tech/ts-to-vba.git"
  },
  "keywords": [
    "typescript",
    "vba",
    "excel",
    "transpiler",
    "tstvba"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tstvba": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/vba/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "jest --runInBand",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "fix:prettier": "prettier --write .",
    "check": "npm run lint && npm run test && npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check",
    "bundle": "npm run check && node dist/cli.js -p ."
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "enhanced-resolve": "5.18.3",
    "picomatch": "^2.3.1",
    "source-map": "^0.7.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.11",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "typescript": "5.8.2"
  }
}
